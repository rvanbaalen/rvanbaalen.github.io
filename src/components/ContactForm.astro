---
// Contact form with client-side validation, submit feedback, and error handling.
// Posts to /api/contact (Cloudflare Function).
// Turnstile widget loads from Cloudflare CDN.
---

<form
  id="contact-form"
  class="grid grid-cols-1 gap-2.5 sm:grid-cols-2"
  novalidate
>
  <label class="group flex items-center gap-2 rounded-md border border-edge bg-[var(--color-base)] px-3.5 py-3 font-sans text-[16px] text-muted transition-[border-color,box-shadow,color] duration-200 focus-within:border-accent focus-within:shadow-[0_0_0_3px_var(--color-accent-glow)] focus-within:text-secondary">
    <i class="ph ph-user text-sm text-dim transition-colors duration-200" aria-hidden="true" />
    <input
      type="text"
      name="name"
      placeholder="Name"
      aria-label="Name"
      required
      class="w-full bg-transparent text-secondary placeholder:text-muted/60 outline-none font-sans text-[16px]"
    />
  </label>
  <label class="group flex items-center gap-2 rounded-md border border-edge bg-[var(--color-base)] px-3.5 py-3 font-sans text-[16px] text-muted transition-[border-color,box-shadow,color] duration-200 focus-within:border-accent focus-within:shadow-[0_0_0_3px_var(--color-accent-glow)] focus-within:text-secondary">
    <i class="ph ph-at text-sm text-dim transition-colors duration-200" aria-hidden="true" />
    <input
      type="email"
      name="email"
      placeholder="Email"
      aria-label="Email"
      required
      class="w-full bg-transparent text-secondary placeholder:text-muted/60 outline-none font-sans text-[16px]"
    />
  </label>
  <label class="group flex items-center gap-2 rounded-md border border-edge bg-[var(--color-base)] px-3.5 py-3 font-sans text-[16px] text-muted transition-[border-color,box-shadow,color] duration-200 focus-within:border-accent focus-within:shadow-[0_0_0_3px_var(--color-accent-glow)] focus-within:text-secondary sm:col-span-2">
    <i class="ph ph-text-aa text-sm text-dim transition-colors duration-200" aria-hidden="true" />
    <input
      type="text"
      name="subject"
      placeholder="Subject"
      aria-label="Subject"
      required
      class="w-full bg-transparent text-secondary placeholder:text-muted/60 outline-none font-sans text-[16px]"
    />
  </label>
  <label class="group flex gap-2 rounded-md border border-edge bg-[var(--color-base)] px-3.5 pt-3 pb-3 font-sans text-[16px] text-muted transition-[border-color,box-shadow,color] duration-200 focus-within:border-accent focus-within:shadow-[0_0_0_3px_var(--color-accent-glow)] focus-within:text-secondary sm:col-span-2">
    <i class="ph ph-pencil-simple mt-0.5 text-sm text-dim transition-colors duration-200" aria-hidden="true" />
    <textarea
      name="message"
      placeholder="Your message..."
      aria-label="Your message"
      required
      rows="5"
      class="w-full resize-y bg-transparent text-secondary placeholder:text-muted/60 outline-none font-sans text-[16px]"
    />
  </label>

  <div class="cf-turnstile sm:col-span-2" data-sitekey="0x4AAAAAACxDAFMK251wjSdQ"></div>
  <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

  <!-- Feedback area -->
  <div id="form-feedback" class="hidden sm:col-span-2 rounded-md px-4 py-3 font-sans text-[15px]" role="alert"></div>

  <button
    type="submit"
    id="submit-btn"
    class="flex items-center justify-center gap-2 rounded-md bg-accent px-6 py-3 font-sans text-[16px] font-medium text-[var(--color-base)] transition-[background,transform,box-shadow] duration-150 hover:bg-accent-bright hover:-translate-y-px hover:shadow-[0_4px_12px_var(--color-accent-glow)] active:translate-y-0 disabled:opacity-50 disabled:pointer-events-none sm:col-span-2"
  >
    <i class="ph ph-paper-plane-tilt" aria-hidden="true" />
    <span>Send message</span>
  </button>
</form>

<script is:inline>
  (function() {
    function initContactForm() {
      var form = document.getElementById('contact-form');
      if (!form || form.dataset.init) return;
      form.dataset.init = 'true';

      var feedback = document.getElementById('form-feedback');
      var btn = document.getElementById('submit-btn');
      var btnIcon = btn.querySelector('i');
      var btnText = btn.querySelector('span');

      function showFeedback(msg, type) {
        feedback.textContent = msg;
        feedback.className = 'sm:col-span-2 rounded-md px-4 py-3 font-sans text-[15px]';
        if (type === 'error') {
          feedback.className += ' border border-[var(--color-error)] bg-[var(--color-error)]/5 text-[var(--color-error)]';
        } else if (type === 'success') {
          feedback.className += ' border border-[var(--color-green)] bg-[var(--color-green)]/5 text-[var(--color-green)]';
        }
        feedback.removeAttribute('hidden');
        feedback.classList.remove('hidden');
      }

      function hideFeedback() {
        feedback.classList.add('hidden');
      }

      function setLoading(loading) {
        btn.disabled = loading;
        if (loading) {
          btnIcon.className = 'ph ph-circle-notch animate-spin';
          btnText.textContent = 'Sending...';
        } else {
          btnIcon.className = 'ph ph-paper-plane-tilt';
          btnText.textContent = 'Send message';
        }
      }

      function markInvalid(input, msg) {
        var label = input.closest('label');
        label.classList.add('!border-[var(--color-error)]');
        input.setAttribute('aria-invalid', 'true');
      }

      function clearInvalid(input) {
        var label = input.closest('label');
        label.classList.remove('!border-[var(--color-error)]');
        input.removeAttribute('aria-invalid');
      }

      // Clear validation on input
      form.querySelectorAll('input, textarea').forEach(function(el) {
        el.addEventListener('input', function() { clearInvalid(el); hideFeedback(); });
      });

      form.addEventListener('submit', function(e) {
        e.preventDefault();
        hideFeedback();

        // Client-side validation
        var fields = form.querySelectorAll('[required]');
        var firstInvalid = null;
        fields.forEach(function(field) {
          clearInvalid(field);
          var empty = !field.value.trim();
          var badEmail = field.type === 'email' && field.value.trim() && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(field.value.trim());
          if (empty || badEmail) {
            markInvalid(field);
            if (!firstInvalid) firstInvalid = field;
          }
        });

        if (firstInvalid) {
          firstInvalid.focus();
          showFeedback('Please fill in all fields correctly.', 'error');
          return;
        }

        // Check Turnstile
        var turnstile = form.querySelector('[name="cf-turnstile-response"]');
        if (!turnstile || !turnstile.value) {
          showFeedback('Please complete the security check.', 'error');
          return;
        }

        setLoading(true);

        fetch('/api/contact', {
          method: 'POST',
          body: new FormData(form),
        }).then(function(res) {
          if (res.ok || res.redirected) {
            form.reset();
            if (typeof turnstile !== 'undefined' && window.turnstile) {
              window.turnstile.reset();
            }
            showFeedback('Message sent! I\'ll get back to you soon.', 'success');
          } else {
            return res.text().then(function(t) { throw new Error(t); });
          }
        }).catch(function(err) {
          showFeedback(err.message || 'Something went wrong. Please try again.', 'error');
        }).finally(function() {
          setLoading(false);
        });
      });
    }

    initContactForm();
    document.addEventListener('astro:page-load', initContactForm);
  })();
</script>
