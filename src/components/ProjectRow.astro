---
interface Props {
  name: string;
  description: string;
  tech: string[];
  url?: string;
  repo: string;
}

const { name, description, tech, url, repo } = Astro.props;
const href = url || repo;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class="group block rounded-md border-b border-edge-subtle px-3.5 py-4 transition-colors duration-150 hover:bg-surface"
>
  <div class="flex items-baseline justify-between gap-4">
    <span class="text-[15px] font-medium text-primary transition-colors duration-150 group-hover:text-accent-bright">
      {name}
    </span>
    <span class="shrink-0 font-mono text-[10px] uppercase tracking-widest text-dim">
      {tech.join(" · ")}
    </span>
  </div>
  <p class="mt-1 text-sm leading-relaxed text-muted">
    {description}
  </p>
</a>
