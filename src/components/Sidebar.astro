---
import NavItem from "./NavItem.astro";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const navItems = [
  { href: "/", icon: "house", label: "Home" },
  { href: "/articles", icon: "article", label: "Articles" },
  { href: "/projects", icon: "code", label: "Projects" },
  { href: "/about", icon: "user-circle", label: "About" },
  { href: "/contact", icon: "envelope-simple", label: "Contact" },
];

function isActive(href: string, current: string): boolean {
  if (href === "/") return current === "/";
  return current.startsWith(href);
}
---

<div class="sticky top-0 h-screen p-4 pr-0 hidden md:block" transition:persist>
  <aside class="flex h-full flex-col rounded-xl border border-edge bg-surface/70 backdrop-blur-[16px] p-8 pb-6 transition-colors duration-300">
    <img
      src="/images/avatar.png"
      alt="Robin van Baalen"
      class="mb-3.5 h-14 w-14 rounded-full border-2 border-edge"
      width="56"
      height="56"
    />
    <p class="text-[15px] font-semibold text-primary">Robin van Baalen</p>
    <p class="mb-7 font-sans text-[13px] leading-snug text-muted">
      Software engineer &amp; consultant. Building tools, writing code, solving problems.
    </p>
    <nav class="relative flex flex-1 flex-col gap-0.5" aria-label="Main navigation" data-sidebar-nav>
      <span
        class="absolute left-0 z-10 h-1 w-1 rounded-full bg-accent-bright animate-[pulse-dot_2s_ease-in-out_infinite] transition-[top] duration-300 ease-out"
        data-nav-dot
        aria-hidden="true"
      />
      {navItems.map((item) => (
        <NavItem
          href={item.href}
          icon={item.icon}
          label={item.label}
          active={isActive(item.href, currentPath)}
        />
      ))}
    </nav>

    <script>
      function updateActiveNav() {
        const path = window.location.pathname;
        const items = document.querySelectorAll("[data-nav-item]");
        items.forEach((item) => {
          const href = item.getAttribute("href") || "";
          const isActive = href === "/" ? path === "/" : path.startsWith(href);
          if (isActive) {
            item.setAttribute("data-active", "true");
            item.classList.remove("text-muted", "hover:text-primary");
            item.classList.add("text-accent-bright", "active");
          } else {
            item.removeAttribute("data-active");
            item.classList.remove("text-accent-bright", "active");
            item.classList.add("text-muted", "hover:text-primary");
          }
        });
      }

      function positionNavDot() {
        updateActiveNav();
        const nav = document.querySelector("[data-sidebar-nav]");
        const dot = document.querySelector("[data-nav-dot]") as HTMLElement;
        const active = document.querySelector("[data-nav-item][data-active]") as HTMLElement;
        if (!nav || !dot || !active) {
          if (dot) dot.style.opacity = "0";
          return;
        }
        const navRect = nav.getBoundingClientRect();
        const activeRect = active.getBoundingClientRect();
        const top = activeRect.top - navRect.top + activeRect.height / 2 - 2;
        dot.style.top = `${top}px`;
        dot.style.opacity = "1";
      }
      positionNavDot();
      document.addEventListener("astro:after-swap", positionNavDot);

      // Dot tracks hovered nav item, returns to active on leave
      document.querySelectorAll("[data-nav-item]").forEach((item) => {
        item.addEventListener("mouseenter", () => {
          const nav = document.querySelector("[data-sidebar-nav]");
          const dot = document.querySelector("[data-nav-dot]") as HTMLElement;
          if (!nav || !dot) return;
          const navRect = nav.getBoundingClientRect();
          const itemRect = item.getBoundingClientRect();
          dot.style.top = `${itemRect.top - navRect.top + itemRect.height / 2 - 2}px`;
        });
        item.addEventListener("mouseleave", () => {
          positionNavDot();
        });
      });
    </script>
    <div class="mt-auto border-t border-edge pt-4">
      <div class="relative mb-3 flex h-8 w-full rounded-lg border border-edge bg-[var(--color-base)] p-0.5" data-theme-switch aria-label="Theme switcher" role="radiogroup">
        <div class="absolute top-0.5 left-0.5 h-[calc(100%-4px)] w-[calc(33.333%-2px)] rounded-md bg-surface-hover transition-transform duration-200 ease-[cubic-bezier(0.22,1,0.36,1)]" data-theme-slider aria-hidden="true"></div>
        <button class="group relative z-10 flex flex-1 cursor-pointer items-center justify-center rounded-md text-dim transition-colors duration-150 hover:text-secondary" data-theme-opt="light" role="radio" aria-label="Light mode">
          <i class="ph ph-sun text-[15px]" aria-hidden="true"></i>
          <span class="pointer-events-none absolute -top-8 left-1/2 -translate-x-1/2 rounded-md bg-surface border border-edge px-2 py-0.5 font-sans text-[11px] text-muted opacity-0 transition-opacity duration-150 group-hover:opacity-100 whitespace-nowrap">Light</span>
        </button>
        <button class="group relative z-10 flex flex-1 cursor-pointer items-center justify-center rounded-md text-dim transition-colors duration-150 hover:text-secondary" data-theme-opt="auto" role="radio" aria-label="Auto (system)">
          <i class="ph ph-monitor text-[15px]" aria-hidden="true"></i>
          <span class="pointer-events-none absolute -top-8 left-1/2 -translate-x-1/2 rounded-md bg-surface border border-edge px-2 py-0.5 font-sans text-[11px] text-muted opacity-0 transition-opacity duration-150 group-hover:opacity-100 whitespace-nowrap">System</span>
        </button>
        <button class="group relative z-10 flex flex-1 cursor-pointer items-center justify-center rounded-md text-dim transition-colors duration-150 hover:text-secondary" data-theme-opt="dark" role="radio" aria-label="Dark mode">
          <i class="ph ph-moon text-[15px]" aria-hidden="true"></i>
          <span class="pointer-events-none absolute -top-8 left-1/2 -translate-x-1/2 rounded-md bg-surface border border-edge px-2 py-0.5 font-sans text-[11px] text-muted opacity-0 transition-opacity duration-150 group-hover:opacity-100 whitespace-nowrap">Dark</span>
        </button>
      </div>
      <script>
        function initThemeSwitch() {
          const sw = document.querySelector("[data-theme-switch]");
          if (!sw || sw.hasAttribute("data-theme-init")) return;
          sw.setAttribute("data-theme-init", "");

          const slider = sw.querySelector("[data-theme-slider]") as HTMLElement;
          const opts = sw.querySelectorAll("[data-theme-opt]");
          const positions = { light: "translateX(0%)", auto: "translateX(100%)", dark: "translateX(200%)" };

          function getSystemTheme() {
            return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
          }

          function applyTheme(pref: string) {
            const resolved = pref === "auto" ? getSystemTheme() : pref;
            document.documentElement.setAttribute("data-theme", resolved);
          }

          function updateUI() {
            const pref = localStorage.getItem("theme-pref") || "auto";
            slider.style.transform = positions[pref as keyof typeof positions] || positions.auto;
            opts.forEach((opt) => {
              const val = opt.getAttribute("data-theme-opt");
              if (val === pref) {
                opt.classList.remove("text-dim");
                opt.classList.add("text-primary");
                opt.setAttribute("aria-checked", "true");
              } else {
                opt.classList.remove("text-primary");
                opt.classList.add("text-dim");
                opt.setAttribute("aria-checked", "false");
              }
            });
          }

          opts.forEach((opt) => {
            opt.addEventListener("click", () => {
              const pref = opt.getAttribute("data-theme-opt") || "auto";
              localStorage.setItem("theme-pref", pref);
              if (pref === "auto") {
                localStorage.removeItem("theme");
              } else {
                localStorage.setItem("theme", pref);
              }
              applyTheme(pref);
              updateUI();
            });
          });

          window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", () => {
            const pref = localStorage.getItem("theme-pref") || "auto";
            if (pref === "auto") applyTheme("auto");
          });

          updateUI();
          applyTheme(localStorage.getItem("theme-pref") || "auto");
        }
        initThemeSwitch();
        document.addEventListener("astro:after-swap", initThemeSwitch);
      </script>
      <div class="mb-2.5 flex gap-3.5">
        <a href="https://github.com/rvanbaalen" class="text-dim text-lg transition-colors duration-150 hover:text-accent-bright" aria-label="GitHub">
          <i class="ph ph-github-logo" />
        </a>
        <a href="https://www.linkedin.com/in/robinvanbaalen/" class="text-dim text-lg transition-colors duration-150 hover:text-accent-bright" aria-label="LinkedIn">
          <i class="ph ph-linkedin-logo" />
        </a>
      </div>
      <p class="font-sans text-[10px] text-dim">&copy; 2026 Robin van Baalen</p>
    </div>
  </aside>
</div>
