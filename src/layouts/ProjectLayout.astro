---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  name: string;
  description: string;
  repo: string;
  version?: string;
  tech?: string[];
}

const { name, description, repo, version, tech } = Astro.props;
---

<BaseLayout title={`${name} — Robin van Baalen`} description={description}>
  <article>
    <header class="mb-10">
      <a
        href="/projects"
        class="mb-6 inline-flex items-center gap-1.5 font-sans text-[14px] text-muted transition-colors duration-150 hover:text-accent"
      >
        <i class="ph ph-arrow-left text-[13px]" aria-hidden="true" />
        All projects
      </a>
      <h1 class="mb-3 text-3xl font-normal leading-tight tracking-tight text-primary md:text-4xl">
        {name}
      </h1>
      <p class="mb-4 text-lg text-muted">{description}</p>
      <div class="flex flex-wrap items-center gap-3 font-sans text-[13px] text-dim">
        {version && (
          <span class="rounded bg-accent-subtle px-2.5 py-0.5 font-medium text-accent-bright">
            v{version}
          </span>
        )}
        {tech && tech.map((t) => (
          <span class="rounded bg-surface px-2.5 py-0.5 text-muted">
            {t}
          </span>
        ))}
        <a
          href={`https://github.com/${repo}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1 text-accent transition-colors duration-150 hover:text-accent-bright"
        >
          <i class="ph ph-github-logo text-sm" aria-hidden="true" />
          Source
        </a>
      </div>
    </header>
    <div class="prose prose-invert max-w-none prose-headings:font-serif prose-headings:font-normal prose-headings:tracking-tight prose-headings:text-primary prose-p:text-secondary prose-a:text-accent prose-a:no-underline hover:prose-a:underline prose-code:text-accent-bright prose-code:font-mono prose-code:text-[0.9em] prose-pre:bg-surface prose-pre:border prose-pre:border-edge prose-strong:text-primary prose-blockquote:border-accent-dim prose-blockquote:text-muted prose-li:text-secondary prose-th:text-primary prose-td:text-secondary">
      <slot />
    </div>
  </article>
</BaseLayout>
